{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      ".git",
      ".DS_Store",
      ".wrangler",
      "node_modules",
      ".gitignore",
      ".wranglerignore",
      "wrangler.toml",
      "wrangler.jsonc",
      "README.md",
      "*.log"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
